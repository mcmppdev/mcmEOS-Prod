# Local development can use a local Postgres URL.
# Vercel production should use the Supabase shared transaction pooler on port 6543 with SSL.
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres
SESSION_SECRET=change-this-secret
NODE_ENV=development
APP_ENV=prod
PORT=4173
LEADERSHIP_MONTHLY_LIMIT=3000

# Vercel deployments must set APP_ENV explicitly:
# Dev project: APP_ENV=dev
# Prod project: APP_ENV=prod
